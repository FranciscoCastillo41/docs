{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Vintl",
  "description": "Point-in-time macro-economic and treasury data API.",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg",
    "href": "/"
  },
  "favicon": "/logo.png",
  "theme": "maple",
  "appearance": {
    "default": "light"
  },
  "colors": {
    "primary": "#10b981",
    "light": "#059669",
    "dark": "#34d399"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#0a0a0a"
    }
  },
  "fonts": {
    "heading": {
      "family": "Geist Sans",
      "weight": 700
    },
    "body": {
      "family": "Geist Sans",
      "weight": 400
    }
  },
  "styling": {
    "codeblocks": {},
    "css": "/global.css"
  },
  "search": {
    "prompt": "Search docs..."
  },
  "thumbnails": {
    "appearance": "light",
    "background": "#ffffff",
    "color": "#0a0a0a",
    "fonts": {
      "family": "Geist Sans"
    }
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Vintl API Docs",
      "og:image:alt": "Vintl — Point-in-time financial data API",
      "twitter:card": "summary_large_image"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "topbar": {
    "links": [
      { "name": "Explore", "url": "https://vintl.io/explore" },
      { "name": "Status", "url": "https://status.vintl.io" }
    ],
    "cta": {
      "name": "Get API Key",
      "url": "https://vintl.io/sign-up"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "play",
            "pages": ["index", "quickstart", "essentials/authentication"]
          },
          {
            "group": "Core Concepts",
            "icon": "puzzle-piece",
            "pages": ["essentials/rate-limits", "essentials/errors", "essentials/pagination"]
          },
          {
            "group": "Guides",
            "icon": "map",
            "pages": [
              "guides/point-in-time",
              "guides/yield-curve",
              "guides/revisions",
              "guides/python-quickstart",
              "guides/ai-agents"
            ]
          },
          {
            "group": "Changelog",
            "icon": "clock",
            "pages": ["changelog"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "openapi": "openapi/v1.yaml"
      }
    ]
  },
  "api": {
    "baseUrl": "https://api.vintl.io",
    "auth": {
      "method": "key",
      "name": "X-API-Key"
    },
    "playground": {
      "mode": "simple"
    }
  },
  "footerSocials": {
    "github": "https://github.com/FranciscoCastillo41",
    "twitter": "https://x.com/vintl"
  }
}
