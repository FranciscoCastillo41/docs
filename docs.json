{
  "$schema": "https://mintlify.com/docs.json",
  "name": "MacroData API",
  "description": "Point-in-time macro-economic and treasury data API.",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg",
    "href": "/"
  },
  "favicon": "/favicon.svg",
  "theme": "linden",
  "appearance": {
    "default": "dark"
  },
  "colors": {
    "primary": "#F59E0B",
    "light": "#FBBF24",
    "dark": "#D97706"
  },
  "background": {
    "decoration": "windows"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "styling": {
    "codeblocks": "dark"
  },
  "search": {
    "prompt": "Search docs..."
  },
  "thumbnails": {
    "appearance": "dark",
    "fonts": {
      "family": "Inter"
    }
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "MacroData API Docs",
      "twitter:card": "summary_large_image"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "topbar": {
    "links": [
      { "name": "Dashboard", "url": "https://app.macrodata.dev" },
      { "name": "Status", "url": "https://status.macrodata.dev" }
    ],
    "cta": {
      "name": "Get API Key",
      "url": "https://app.macrodata.dev/signup"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "play",
            "pages": ["index", "quickstart", "essentials/authentication"]
          },
          {
            "group": "Core Concepts",
            "icon": "puzzle-piece",
            "pages": ["essentials/rate-limits", "essentials/errors", "essentials/pagination"]
          },
          {
            "group": "Guides",
            "icon": "map",
            "pages": [
              "guides/point-in-time",
              "guides/yield-curve",
              "guides/revisions",
              "guides/python-quickstart",
              "guides/ai-agents"
            ]
          },
          {
            "group": "Changelog",
            "icon": "clock",
            "pages": ["changelog"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "openapi": "openapi/v1.yaml"
      }
    ]
  },
  "api": {
    "baseUrl": "https://api.macrodata.dev",
    "auth": {
      "method": "key",
      "name": "X-API-Key"
    },
    "playground": {
      "mode": "simple"
    }
  },
  "footerSocials": {
    "github": "https://github.com/FranciscoCastillo41",
    "twitter": "https://x.com/macrodata"
  }
}
